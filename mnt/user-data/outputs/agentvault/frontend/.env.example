# ============================================================
# AgentVault Frontend — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# --- Auth0 (Required) ---
# Generate a long random secret: openssl rand -hex 32
AUTH0_SECRET=your_super_long_random_secret_here_at_least_32_chars

# Your deployed frontend URL (use http://localhost:3000 for dev)
AUTH0_BASE_URL=http://localhost:3000

# Your Auth0 domain
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com

# From Auth0 Dashboard > Applications > Your App
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here

# --- Backend API URL ---
NEXT_PUBLIC_API_URL=http://localhost:4000
